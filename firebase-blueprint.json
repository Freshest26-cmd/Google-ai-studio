{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's access level."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a purchase made by a user.",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string",
          "description": "Unique order identifier."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "total": {
          "type": "number",
          "description": "Total order amount."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "shipped", "delivered"],
          "description": "Current status of the order."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "items", "total", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order documents."
    }
  }
}
